<Window
    x:Class="Sidekick.Wpf.PopupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Sidekick"
    Width="460"
    SizeToContent="Height"
    MinHeight="180"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    Background="#1E1E1E"
    Foreground="#F5F5F5">

    <Border
        Padding="24"
        Background="#1E1E1E"
        BorderBrush="#3A3A3A"
        BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                x:Name="MessageTextBlock"
                Grid.Row="0"
                FontSize="15"
                LineHeight="22"
                TextWrapping="Wrap" />

            <StackPanel
                Grid.Row="2"
                HorizontalAlignment="Right"
                Orientation="Horizontal">

                <Button
                    x:Name="CancelButton"
                    MinWidth="90"
                    Margin="0,0,8,0"
                    Padding="14,8"
                    Background="#2D2D2D"
                    BorderBrush="#555555"
                    Foreground="#F5F5F5"
                    Click="CancelButton_Click"
                    Content="Cancel" />

                <Button
                    x:Name="ConfirmButton"
                    MinWidth="90"
                    Padding="14,8"
                    Background="#3B82F6"
                    BorderBrush="#3B82F6"
                    Foreground="#FFFFFF"
                    Click="ConfirmButton_Click"
                    Content="OK" />
            </StackPanel>
        </Grid>
    </Border>
</Window>