<Window
    x:Class="Sidekick.Wpf.TransparentFocusWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="1"
    Height="1"
    WindowStyle="None"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    ShowActivated="True"
    Topmost="True"
    AllowsTransparency="True"
    Background="#01000000"
    Focusable="True"
    Cursor="Arrow"
    Loaded="TransparentFocusWindow_Loaded"
    ContentRendered="TransparentFocusWindow_ContentRendered"
    Deactivated="TransparentFocusWindow_Deactivated"
    PreviewMouseDown="TransparentFocusWindow_PreviewMouseDown"
    PreviewMouseUp="TransparentFocusWindow_PreviewMouseUp"
    PreviewKeyDown="TransparentFocusWindow_PreviewKeyDown">

    <Border
        Width="1"
        Height="1"
        Background="#01000000"
        Focusable="True" />
</Window>