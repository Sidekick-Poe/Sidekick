@using Sidekick.Apis.Poe.Trade.ApiItems
@using Sidekick.Common.Exceptions
@using Sidekick.Data.Items

@if (Small)
{
    <div class="flex flex-nowrap gap-0.5 items-center justify-end text-white">
        <Heading3>@Value.ToString("0.##")</Heading3>
        @if (Definition.TradeItem?.Image != null)
        {
            <TextCaption Class="text-[#a38d6d]">&times;</TextCaption>

            <Tooltip Text="@Definition.BaseItem?.Name">
                <ChildContent>
                    <img src="@Definition.TradeItem?.Image" class="max-h-5" alt="@Definition.BaseItem?.Name" />
                </ChildContent>
            </Tooltip>
        }
    </div>
}
else
{
    <div class="flex flex-nowrap gap-1 items-center justify-end text-white">
        <Heading2>@Value.ToString("0.##")</Heading2>
        @if (Definition.TradeItem?.Image != null)
        {
            <TextBase Class="text-[#a38d6d]">&times;</TextBase>
            <Tooltip Text="@Definition.BaseItem?.Name">
                <ChildContent>
                    <img src="@Definition.TradeItem?.Image" class="max-h-10" alt="@Definition.BaseItem?.Name" />
                </ChildContent>
            </Tooltip>
        }
    </div>
}

@inject IApiItemProvider ApiItemProvider

@code {

    [Parameter]
    public ItemDefinition? Currency { get; set; }

    [Parameter]
    public decimal Value { get; set; }

    [Parameter]
    public bool Small { get; set; }

    private ItemDefinition Definition => Currency ?? ApiItemProvider.ChaosOrb ?? throw new SidekickException("The currency could not be determined.");

}
