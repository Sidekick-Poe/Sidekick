@using Sidekick.Apis.PoeDb
@using Sidekick.Data.Items
@using Sidekick.Data

<ButtonLink Class="justify-start! p-3 gap-2" OnClick="() => PoeDbClient.OpenWebsite(Item)">
    <Icon Svg="@UiIcons.External" /> @(Item.Game == GameType.PathOfExile1 ? "poedb.tw" : "poe2db.tw")
</ButtonLink>

@inject IPoeDbClient PoeDbClient

@code {

    [CascadingParameter]
    public required Item Item { get; set; }


}
