@using Sidekick.Apis.Poe.Trade.Parser.Stats
@using Sidekick.Apis.PoeNinja.Stash
@using Sidekick.Data.Languages
@using Sidekick.Data.Stats
@using Sidekick.Modules.Items.Components
@using Sidekick.Modules.Items.PoeNinja.Localization
@using Sidekick.Modules.Items.Trade.Localization

<div class="mb-2 bg-stone-950 rounded-lg px-2 py-1">
    <div class="flex flex-wrap mb-1">
        <div class="flex w-1/3 justify-center">
            <PriceDisplay Value="Stash.ChaosValue" Currency="chaos"/>
        </div>
        <div class="flex w-1/3 justify-center">
            <PriceDisplay Value="Stash.ExaltedValue" Currency="exalted"/>
        </div>
        <div class="flex w-1/3 justify-center">
            <PriceDisplay Value="Stash.DivineValue" Currency="divine"/>
        </div>
    </div>

    <TextCaption Class="text-center">@Stash.ListingCount @NinjaResources["Listings"]</TextCaption>
    @if (Stash.Definition.Stash != null)
    {
        if (Stash.Definition.Stash.ItemLevel > 0)
        {
            <ItemPropertyText Label="@CurrentGameLanguage.Language.DescriptionItemLevel"
                              Value="@Stash.Definition.Stash.ItemLevel.ToString()"
                              Class="text-center justify-center"/>
        }

        if (Stash.Definition.Stash.GemLevel > 0)
        {
            <ItemPropertyText Label="@CurrentGameLanguage.Language.DescriptionLevel"
                              Value="@Stash.Definition.Stash.GemLevel.ToString()"
                              Class="text-center justify-center"/>
        }

        if (Stash.Definition.Stash.GemQuality > 0)
        {
            <ItemPropertyText Label="@CurrentGameLanguage.Language.DescriptionQuality"
                              Value="@Stash.Definition.Stash.GemQuality.ToString()"
                              Class="text-center justify-center"/>
        }

        if (Stash.Definition.Stash.Stats != null)
        {
            foreach (var stat in Stash.Definition.Stash.Stats)
            {
                if (string.IsNullOrEmpty(stat.Id)) continue;
                var key = StatParser.GetDictionaryKey(stat.Id, stat.Option);
                var tradeStat = StatParser.TradeDictionary.GetValueOrDefault(key);
                if (tradeStat == null) continue;

                var category = StatCategory.Explicit;
                if (tradeStat.Id.StartsWith("explicit")) category = StatCategory.Mutated;
                if (tradeStat.Id.StartsWith("enchant")) category = StatCategory.Enchant;

                if (stat.Value > 0)
                {
                    <ItemStatText Category="category" Class="text-center">@tradeStat.Text.Replace("#", stat.Value.ToString())</ItemStatText>
                }
                else
                {
                    <ItemStatText Category="category" Class="text-center">@tradeStat.Text</ItemStatText>
                }
            }
        }

        if (Stash.Definition.Stash.Corrupted == true)
        {
            <ItemStatText Category="StatCategory.Corrupted" Class="text-center">@TradeResources["Corrupted"]</ItemStatText>
        }

        if (!string.IsNullOrEmpty(Stash.Definition.Stash.Variant))
        {
            <ItemStatText Category="StatCategory.GrayText"
                          Class="text-sm text-center">@Stash.Definition.Stash.Variant.Trim(' ', ',')</ItemStatText>
        }
    }
</div>

<PoeNinjaSparkline Sparkline="Stash.Sparkline"/>

@if (Stash.ListingCount < 5)
{
    <AlertError IsCritical="true" Flat="true">@NinjaResources["LowConfidence"]</AlertError>
}
else if (Stash.ListingCount < 10)
{
    <AlertError IsCritical="false" Flat="true">@NinjaResources["MediumConfidence"]</AlertError>
}

@inject IStringLocalizer<PoeNinjaResources> NinjaResources
@inject IStringLocalizer<TradeResources> TradeResources
@inject ICurrentGameLanguage CurrentGameLanguage
@inject IStatParser StatParser

@code {

    [Parameter]
    public required NinjaStash Stash { get; set; }

}
