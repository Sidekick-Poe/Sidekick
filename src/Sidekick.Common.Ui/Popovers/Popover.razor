@using Sidekick.Common.Ui.Sections
@using Sidekick.Common.Enums

@if (!Ready) return;

<FlowbiteComponent Script="popover"
                   ScriptParameters="@([
                                         Id,
                                         Reference!,
                                         Placement.GetValueAttribute(),
                                         Trigger.GetValueAttribute(),
                                     ])"
                   class="flex">
    @ActivatorContent
</FlowbiteComponent>

<BodySectionContent SectionName="@Id">
    <div id="@Id"
         class="absolute z-10 invisible opacity-0 transition-opacity duration-300 border border-solid border-stone-800 bg-black text-white grow overflow-y-auto overflow-x-hidden p-2 rounded-lg shadow-lg @Class"
         @onclick="() => {}"
         @onclick:preventDefault="true"
         @onclick:stopPropagation="true">
        @ChildContent
    </div>
</BodySectionContent>

@code {

    [Parameter]
    public required RenderFragment ChildContent { get; set; }

    [Parameter]
    public required RenderFragment ActivatorContent { get; set; }

    [Parameter]
    public TooltipPlacement Placement { get; set; } = TooltipPlacement.Top;

    [Parameter]
    public PopoverTrigger Trigger { get; set; } = PopoverTrigger.Click;

    [Parameter]
    public EventCallback OnShow { get; set; }

    [Parameter]
    public string Class { get; set; } = "max-h-[550px] max-w-[350px]";

    private string Id { get; } = UiUtilities.GenerateId();

    private bool Ready { get; set; }

    private DotNetObjectReference<Popover>? Reference { get; set; }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            Reference = DotNetObjectReference.Create(this);
            Ready = true;
            StateHasChanged();
        }

        base.OnAfterRender(firstRender);
    }

    [JSInvokable("OnShow")]
    public async Task OnShowCallback()
    {
        await OnShow.InvokeAsync();
    }

}
