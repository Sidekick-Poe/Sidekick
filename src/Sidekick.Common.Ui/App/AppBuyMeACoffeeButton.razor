@using Sidekick.Common.Browser
@using Sidekick.Common.Ui.Localization

<Tooltip Text="@Resources["BuyMeACoffee"]">
    <button @onclick="@OpenWebsite">
        <img src="@Assets["_content/Sidekick.Common.Ui/images/app/buymeacoffee.png"]" alt="@Resources["BuyMeACoffee"]"
             class="w-40"/>
    </button>
</Tooltip>

@inject IBrowserProvider BrowserProvider
@inject IStringLocalizer<UiResources> Resources

@code {

    private void OpenWebsite()
    {
        BrowserProvider.OpenUri(new Uri("https://buymeacoffee.com/sidekickpoe"));
    }

}
