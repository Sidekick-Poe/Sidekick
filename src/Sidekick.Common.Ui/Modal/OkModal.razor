@using Sidekick.Common.Ui.Localization

<Modal @ref="Component"
       ActivatorContent="ActivatorContent">
    <ChildContent>
        <TextBase>@Message</TextBase>
    </ChildContent>
    <FooterContent>
        <ButtonPrimary OnClick="Close">
            @Resources["Close"]
        </ButtonPrimary>
    </FooterContent>
</Modal>

@inject IStringLocalizer<UiResources> Resources

@code {

    [Parameter] public string? Message { get; set; }

    [Parameter] public RenderFragment? ActivatorContent { get; set; }

    [Parameter] public EventCallback OnClose { get; set; }

    public Modal? Component { get; set; }

    private async Task Close()
    {
        await OnClose.InvokeAsync();
        if (Component != null) await Component.Hide();
    }

}