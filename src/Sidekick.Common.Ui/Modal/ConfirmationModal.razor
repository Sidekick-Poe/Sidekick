@using Sidekick.Common.Ui.Localization

<Modal @ref="Component"
       ActivatorContent="ActivatorContent">
    <HeaderContent>
        <Heading3>@Resources["Confirmation_Title"]</Heading3>
    </HeaderContent>
    <ChildContent>
        <TextBase>@Message</TextBase>
    </ChildContent>
    <FooterContent>
        <ButtonSecondary OnClick="No">
            @Resources["Cancel"]
        </ButtonSecondary>
        <ButtonPrimary OnClick="Yes">
            @Resources["Confirm"]
        </ButtonPrimary>
    </FooterContent>
</Modal>

@inject IStringLocalizer<UiResources> Resources

@code {

    [Parameter] public string? Message { get; set; }

    [Parameter] public RenderFragment? ActivatorContent { get; set; }

    [Parameter] public EventCallback OnConfirm { get; set; }

    private Modal? Component { get; set; }

    private async Task Yes()
    {
        await OnConfirm.InvokeAsync();
        if (Component != null) await Component.Hide();
    }

    private async Task No()
    {
        if (Component != null) await Component.Hide();
    }

}
