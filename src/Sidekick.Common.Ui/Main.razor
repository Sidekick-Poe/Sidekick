@using Microsoft.Extensions.Options
@using Sidekick.Common.Platform

<AppWrapper>
    <Router AppAssembly="@typeof(Main).Assembly"
            AdditionalAssemblies="Configuration.Value.Modules"
            NotFoundPage="typeof(NotFound)">
        <Found Context="routeData">
            <RouteView RouteData="@routeData"/>
        </Found>
    </Router>
</AppWrapper>

@inject IOptions<SidekickConfiguration> Configuration
@inject IApplicationService ApplicationService
@inject NavigationManager NavigationManager
@inject IViewLocator ViewLocator
@inject CurrentView CurrentView
@inject SafeJsRuntime JsRuntime

@code {

    private DotNetObjectReference<Main>? Reference { get; set; }

    protected override async Task OnInitializedAsync()
    {
        CurrentView.SetViewType(ViewLocator.LastOpenedType);

        if (!ApplicationService.HasInitialized && !IsInitializePath())
        {
            NavigationManager.NavigateTo("/");
        }

        await base.OnInitializedAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Reference = DotNetObjectReference.Create(this);
            await JsRuntime.InvokeVoidAsync("sidekick.app.navigationManager.register", Reference);
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private bool IsInitializePath()
    {
        var path = new Uri(NavigationManager.Uri).AbsolutePath;
        return path == "/" || path == "/update" || path == "/setup" || path == "/initialize";
    }

    [JSInvokable]
    public void NavigateTo(string url)
    {
        NavigationManager.NavigateTo(url);
    }

}
