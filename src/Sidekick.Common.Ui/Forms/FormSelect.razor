<div>

    @if (!string.IsNullOrEmpty(Label))
    {
        <label id="@LabelId"
               class="flex gap-1 mb-1 text-base font-medium dark:text-zinc-300">
            @Label
            @if (Tooltip is not null)
            {
                <Tooltip Text="@Tooltip"/>
            }
        </label>
    }

    <div class="flex flex-nowrap items-center gap-1 grow">
        <div class="relative w-full">
            <button id="@Id"
                    type="button"
                    aria-haspopup="listbox"
                    aria-expanded="@IsOpen"
                    aria-labelledby="@LabelId @Id"
                    @onclick="Toggle"
                    class="@UiClasses.FormInputClasses p-2 text-base w-full inline-flex items-center justify-between text-left">
                <span class="@GetSelectedTextClasses()">
                    @GetSelectedLabel()
                </span>
                <Icon Svg="@UiIcons.ChevronDown" Size="UiIconSize.Small"/>
            </button>

            @if (IsOpen)
            {
                <button type="button"
                        class="fixed inset-0 z-40 cursor-default bg-transparent"
                        aria-label="Close select"
                        tabindex="-1"
                        @onclick="Close"></button>

                <div class="absolute z-50 mt-1 w-full overflow-hidden rounded-lg border dark:border-zinc-600 dark:bg-zinc-700 shadow-lg">
                    <ul role="listbox"
                        aria-labelledby="@Id"
                        class="max-h-60 overflow-auto p-1 text-base dark:text-white">
                        @if (Options.All(x => GetOptionValue(x.Value) != GetOptionValue(Value)))
                        {
                            <li>
                                <button type="button"
                                        role="option"
                                        aria-selected="true"
                                        @onclick="() => SelectValue(null)"
                                        class="w-full rounded-md px-2 py-2 text-left hover:dark:bg-zinc-600">
                                    &nbsp;
                                </button>
                            </li>
                        }

                        @if (Options.Any(x => x.Group != null))
                        {
                            foreach (var group in Options.GroupBy(x => x.Group))
                            {
                                <li class="px-2 py-1 text-xs font-semibold uppercase tracking-wide dark:text-zinc-400">
                                    @group.Key
                                </li>

                                @foreach (var option in group)
                                {
                                    <li>
                                        <button type="button"
                                                role="option"
                                                aria-selected="@(GetOptionValue(option.Value) == GetOptionValue(Value))"
                                                disabled="@option.Disabled"
                                                @onclick="() => SelectValue(option.Value)"
                                                class="@GetOptionClasses(option)">
                                            @option.Label
                                        </button>
                                    </li>
                                }
                            }
                        }
                        else
                        {
                            foreach (var option in Options)
                            {
                                <li>
                                    <button type="button"
                                            role="option"
                                            aria-selected="@(GetOptionValue(option.Value) == GetOptionValue(Value))"
                                            disabled="@option.Disabled"
                                            @onclick="() => SelectValue(option.Value)"
                                            class="@GetOptionClasses(option)">
                                        @option.Label
                                    </button>
                                </li>
                            }
                        }
                    </ul>
                </div>
            }
        </div>

        @AdornmentContent
    </div>
</div>

@code {

    [Parameter]
    public string? Label { get; set; }

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public List<SelectOption> Options { get; set; } = new();

    [Parameter]
    public string? Tooltip { get; set; }

    [Parameter]
    public RenderFragment? AdornmentContent { get; set; }

    protected string Id { get; } = UiUtilities.GenerateId();

    protected string LabelId { get; } = UiUtilities.GenerateId();

    protected bool IsOpen { get; set; }

    protected string GetOptionValue(string? value)
    {
        if (string.IsNullOrEmpty(value)) return "null";
        return value;
    }

    protected SelectOption? GetOption(string? value)
    {
        var optionValue = GetOptionValue(value);
        return Options.FirstOrDefault(x => GetOptionValue(x.Value) == optionValue);
    }

    protected string GetSelectedLabel()
    {
        return GetOption(Value)?.Label ?? string.Empty;
    }

    protected string GetSelectedTextClasses()
    {
        return GetOption(Value) is null
            ? "block truncate text-zinc-400"
            : "block truncate";
    }

    protected string GetOptionClasses(SelectOption option)
    {
        var isSelected = GetOptionValue(option.Value) == GetOptionValue(Value);

        var classes = "w-full rounded-md px-2 py-0.5 text-left";

        if (option.Disabled)
        {
            return $"{classes} cursor-not-allowed opacity-50";
        }

        if (isSelected)
        {
            return $"{classes} dark:bg-zinc-600 dark:text-white";
        }

        return $"{classes} hover:dark:bg-zinc-600";
    }

    protected void Toggle()
    {
        IsOpen = !IsOpen;
    }

    protected void Close()
    {
        IsOpen = false;
    }

    protected async Task SelectValue(string? value)
    {
        IsOpen = false;
        await ValueChanged.InvokeAsync(value);
    }
}