@using System.Globalization

<div id="@ElementId"
     class="p-[2px] border border-violet-800 bg-violet-300/10 min-w-6 text-center rounded-md whitespace-pre-wrap duration-200 @UiClasses.FocusClasses transition-colors hover:bg-violet-950 [&::selection]:bg-violet-700 [&::selection]:text-violet-200 hover:text-violet-400 hover:border-violet-600 text-violet-500"
     contenteditable="true"
     data-placeholder="@Placeholder">@Value</div>

@inject IJSRuntime JsRuntime
@inject ILogger<FormContentEditable> Logger
@implements IAsyncDisposable

@code {

    [Parameter]
    public string? Placeholder { get; set; }

    [Parameter]
    public string? StringValue { get; set; }

    [Parameter]
    public EventCallback<string?> StringValueChanged { get; set; }

    [Parameter]
    public double? DoubleValue { get; set; }

    [Parameter]
    public EventCallback<double?> DoubleValueChanged { get; set; }

    private IJSObjectReference? JsObject { get; set; }

    private DotNetObjectReference<FormContentEditable>? Reference { get; set; }

    private string ElementId { get; } = UiUtilities.GenerateId();

    private string? Value { get; set; }

    protected override bool ShouldRender() => false;

    protected override async Task OnParametersSetAsync()
    {
        var previousValue = Value;
        if (!string.IsNullOrEmpty(StringValue))
        {
            Value = StringValue;
        }
        else if (DoubleValue != null)
        {
            if (DoubleValue % 1 == 0)
            {
                Value = DoubleValue.Value.ToString(CultureInfo.InvariantCulture);
            }
            else
            {
                Value = DoubleValue.Value.ToString("0.00", CultureInfo.InvariantCulture);
            }
        }
        else
        {
            Value = string.Empty;
        }

        if (JsObject != null && previousValue != Value)
        {
            await UpdateEditable();
        }

        await base.OnParametersSetAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Initialize the IntersectionObserver
        if (firstRender)
        {
            try
            {
                Reference = DotNetObjectReference.Create(this);
                JsObject = await JsRuntime.InvokeAsync<IJSObjectReference>("sidekick.forms.contentEditable", ElementId, Reference);
            }
            catch (Exception e)
            {
                Logger.LogError(e, "Failed to load javascript module.");
            }

            await UpdateEditable();
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    [JSInvokable]
    public async Task Update(string? value)
    {
        if (value == Value) return;
        if (value == Placeholder)
        {
            Value = null;
            await DoubleValueChanged.InvokeAsync(null);
            await StringValueChanged.InvokeAsync(null);
            await UpdateEditable();
            return;
        }

        if (DoubleValueChanged.HasDelegate)
        {
            if (!double.TryParse(value, CultureInfo.InvariantCulture, out var doubleValue)) return;

            Value = doubleValue.ToString(CultureInfo.InvariantCulture);
            await DoubleValueChanged.InvokeAsync(doubleValue);
        }
        else
        {
            Value = value;
            await StringValueChanged.InvokeAsync(value);
        }
    }

    private async Task UpdateEditable()
    {
        if (JsObject != null) await JsObject.InvokeVoidAsync("setValue", Value);
    }

    public async ValueTask DisposeAsync()
    {
        if (JsObject != null)
        {
            await JsObject.InvokeVoidAsync("dispose");
            await JsObject.DisposeAsync();
        }

        Reference?.Dispose();
    }

}
