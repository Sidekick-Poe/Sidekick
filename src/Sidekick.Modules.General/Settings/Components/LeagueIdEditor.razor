@using Microsoft.Extensions.Localization
@using Sidekick.Apis.Poe.Extensions
@using Sidekick.Apis.Poe.Trade.Leagues
@using Sidekick.Common.Cache
@using Sidekick.Common.Settings
@using Sidekick.Common.Ui.Forms

@using Sidekick.Common.Ui.Buttons
@using Sidekick.Common.Ui.Icons

<FormSelect Label="@Resources["Character_League"]"
            Value="@LeagueId"
            ValueChanged="LeagueChanged"
            Options="Options"
            Tooltip="@Resources["League_Hint"]">
    <AdornmentContent>
        <ButtonIcon OnClick="RefreshLeagues"
                    Disabled="Refreshing"
                    Svg="@UiIcons.Refresh"
                    title="@Resources["Refresh"]" />
    </AdornmentContent>
</FormSelect>

@inject IStringLocalizer<SettingsResources> Resources
@inject ISettingsService SettingsService
@inject ILeagueProvider LeagueProvider
@inject NavigationManager NavigationManager
@inject ICacheProvider CacheProvider

@code {

    [Parameter]
    public bool AutoRefresh { get; set; } = true;

    private string? LeagueId { get; set; }

    private List<SelectOption> Options { get; set; } = new();

    private bool Refreshing { get; set; }

    protected override async Task OnInitializedAsync()
    {
        LeagueId = await SettingsService.GetString(SettingKeys.LeagueId);
        await RefreshOptions();
        await base.OnInitializedAsync();
    }

    private async Task RefreshOptions()
    {
        var leagues = await LeagueProvider.GetList(!Refreshing);
        Options = leagues
                  .GroupBy(x => x.Value)
                  .Select(
                      x => new SelectOption()
                          {
                              Value = x.First().Value,
                              Label = x.First().Text,
                              Group = Resources[x.First().Game.ToString()]
                          })
                  .ToList();
    }

    private async Task RefreshLeagues()
    {
        if (Refreshing) return;
        Refreshing = true;
        await RefreshOptions();
        Refreshing = false;
    }

    private async Task LeagueChanged(string? value)
    {
        var currentGame = LeagueId.GetGameFromLeagueId();
        var newGame = value.GetGameFromLeagueId();

        LeagueId = value;
        await SettingsService.Set(SettingKeys.LeagueId, value);

        if (AutoRefresh && currentGame != newGame)
        {
            await CacheProvider.Clear();
            NavigationManager.NavigateTo("/initialize");
        }
    }

}
