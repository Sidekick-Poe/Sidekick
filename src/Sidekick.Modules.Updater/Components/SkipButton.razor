@using Sidekick.Modules.Updater.Localization
@using Sidekick.Common.Ui.Extensions

@if (ShowButton)
{
    <ButtonSecondary OnClick="Skip">@Resources["Skip"]</ButtonSecondary>
}

@inject IStringLocalizer<UpdateResources> Resources
@inject NavigationManager NavigationManager
@inject IViewLocator ViewLocator

@code {

    private bool ShowButton => NavigationManager.QueryString("back") == null;

    public void Skip()
    {
        if (!string.IsNullOrEmpty(NavigationManager.QueryString("back")))
        {
            ViewLocator.Close(SidekickViewType.Splash);
        }
        else
        {
            NavigationManager.NavigateTo("/setup");
        }
    }

}
