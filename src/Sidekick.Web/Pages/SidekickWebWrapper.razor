@using Sidekick.Common.Ui.Views
@using Sidekick.Web.Services

<Sidekick.Common.Ui.Main/>

@inject ICurrentView CurrentView
@inject IServiceProvider ServiceProvider
@implements IDisposable

@code {

    [Inject]
    public required NavigationManager NavigationManager { get; set; }

    protected override void OnInitialized()
    {
        var viewLocator = ServiceProvider.GetService<WebViewLocator>();
        if (viewLocator != null)
        {
            viewLocator.Views.Add(this);
        }

        CurrentView.Closed += CurrentViewClosed;
        base.OnInitialized();
    }

    private void CurrentViewClosed()
    {
        NavigationManager.NavigateTo("/home");
    }

    public void Dispose()
    {
        var viewLocator = ServiceProvider.GetService<WebViewLocator>();
        if (viewLocator != null)
        {
            viewLocator.Views.Remove(this);
        }

        CurrentView.Closed -= CurrentViewClosed;
    }

}
