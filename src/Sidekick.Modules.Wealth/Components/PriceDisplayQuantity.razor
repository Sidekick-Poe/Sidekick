@using Sidekick.Apis.Poe.Trade.ApiItems
@using Sidekick.Common.Exceptions
@using Sidekick.Data.Items

<div class="flex flex-nowrap gap-1 leading-3 items-center">
    <div class="font-medium tracking-tight text-sm">@Quantity</div>
    <div class="font-medium text-base">&times;</div>
    <div class="text-sm opacity-80 text-[#a38d6d]">@Value.ToString("0.##")</div>
    @if (Currency != null)
    {
        <Tooltip Text="@Currency.TradeItem?.Text">
            <img src="@Currency.TradeItem?.Image" class="max-h-4" alt="chaos"/>
        </Tooltip>
    }
</div>

@inject IApiItemProvider ApiItemProvider

@code {

    [Parameter]
    public int Quantity { get; set; }

    [Parameter]
    public decimal Value { get; set; }

    private ItemDefinition? Currency { get; set; }

    protected override void OnParametersSet()
    {
        Currency = ApiItemProvider.Get("chaos") ?? throw new SidekickException("The currency could not be determined.");
        base.OnParametersSet();
    }

}
