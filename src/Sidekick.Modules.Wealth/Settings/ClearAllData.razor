@using Sidekick.Common.Ui.Modal
@using Sidekick.Modules.Wealth.Localization
@using Sidekick.Modules.Wealth.Provider

<div class="flex justify-end">
    <ConfirmationModal Message="@Resources["Clear_All_Data_Confirmation"]"
                       OnConfirm="Clear">
        <ActivatorContent>
            <ButtonSecondary>
                @Resources["Clear_All_Data"]
            </ButtonSecondary>
        </ActivatorContent>
    </ConfirmationModal>
</div>

@inject IStringLocalizer<WealthResources> Resources
@inject WealthProvider WealthProvider

@code {

    private async Task Clear()
    {
        await WealthProvider.Clear();
    }

}
