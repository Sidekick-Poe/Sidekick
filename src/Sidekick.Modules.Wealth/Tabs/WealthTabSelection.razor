@using Microsoft.EntityFrameworkCore
@using Sidekick.Apis.Poe.Account.Authentication
@using Sidekick.Apis.Poe.Account.Stash
@using Sidekick.Apis.Poe.Account.Stash.Models
@using Sidekick.Common.Ui.Popovers
@using Sidekick.Modules.Wealth.Localization
@using Sidekick.Common.Database.Tables
@using Sidekick.Common.Settings
@using Sidekick.Common.Database
@using Sidekick.Common.Enums
@using Sidekick.Modules.Wealth.Authentication
@using Sidekick.Modules.Wealth.Provider

<HideIfUnauthenticated>
    <ChildContent>
        <Popover Placement="TooltipPlacement.Bottom"
                 Class="w-80 max-h-96"
                 OnShow="Refresh">
            <ActivatorContent>
                @if (TrackedTabs.Count > 0)
                {
                    <ButtonCustom Class="border border-green-500 bg-transparent hover:enabled:bg-green-900">
                        <div class="bg-green-400 rounded-full w-2 h-2"></div>
                        <div class="text-green-400">@Resources["Tabs_Selected", TrackedTabs.Count]</div>
                    </ButtonCustom>
                }
                else
                {
                    <ButtonCustom Class="border border-red-500 bg-transparent hover:enabled:bg-red-900">
                        <div class="bg-red-400 rounded-full w-2 h-2"></div>
                        <div class="text-red-400">@Resources["No_Tabs_Selected"]</div>
                    </ButtonCustom>
                }
            </ActivatorContent>
            <ChildContent>
                <Heading3 Class="mb-2">@Resources["Stash_Tabs"]</Heading3>

                @if (Loading)
                {
                    <ProgressBar Indeterminate="true"/>
                }
                else if (StashTabs != null)
                {
                    <div class="flex flex-col gap-1">
                        <AlertInfo>@Resources["Performance_Warning"]</AlertInfo>

                        @foreach (var stashTab in StashTabs)
                        {
                            <FormCheckbox @key="stashTab.Id"
                                          Value="IsChecked(stashTab)"
                                          ValueChanged="(v) => Toggle(stashTab, v)">
                                <div class="flex flex-nowrap items-center gap-1 w-full">
                                    <div class="size-5 -ml-1">
                                        @{
                                            var imageUrl = stashTab.Type.FindAttribute<StashTypeImageAttribute>()?.Path;
                                        }
                                        @if (!string.IsNullOrEmpty(imageUrl) && stashTab.Type.ToString() != imageUrl)
                                        {
                                            <img alt="icon" src="@imageUrl" class="w-5 h-5"/>
                                        }
                                    </div>
                                    <div class="truncate">@stashTab.Name</div>
                                </div>
                            </FormCheckbox>
                        }
                    </div>
                }
            </ChildContent>
        </Popover>
    </ChildContent>
    <UnauthenticatedContent>
        <ButtonCustom Class="border border-neutral-500 bg-transparent"
                      Disabled="true">
            <div class="bg-neutral-400 rounded-full w-2 h-2"></div>
            <div class="text-neutral-400">@Resources["Tabs_Selection"]</div>
        </ButtonCustom>
    </UnauthenticatedContent>
</HideIfUnauthenticated>

@inject IStringLocalizer<WealthResources> Resources
@inject ISettingsService SettingsService
@inject IStashService StashService
@inject DbContextOptions<SidekickDbContext> DbContextOptions
@inject IAuthenticationService AuthenticationService
@inject WealthProvider WealthProvider
@implements IDisposable

@code {

    private List<WealthStash> TrackedTabs { get; set; } = [];

    private List<StashTab>? StashTabs { get; set; }

    private bool Loading { get; set; }

    protected override async Task OnInitializedAsync()
    {
        WealthProvider.OnStatusChanged += OnChanged;
        await UpdateTrackedTabs();
        await base.OnInitializedAsync();
    }

    private async Task Refresh()
    {
        var state = await AuthenticationService.GetCurrentState();
        if (state != AuthenticationState.Authenticated) return;

        Loading = true;
        StateHasChanged();

        await UpdateTrackedTabs();

        await using var dbContext = new SidekickDbContext(DbContextOptions);
        StashTabs = await StashService.GetStashTabList();

        foreach (var trackedTab in TrackedTabs.ToList())
        {
            if (StashTabs.Any(x => x.Id == trackedTab.Id)) continue;
            dbContext.WealthStashes.Remove(trackedTab);
        }

        await dbContext.SaveChangesAsync();

        Loading = false;
        StateHasChanged();
    }

    private void OnChanged()
    {
        InvokeAsync(async () =>
        {
            await UpdateTrackedTabs();
            StateHasChanged();
        });
    }

    private async Task UpdateTrackedTabs()
    {
        var leagueId = await SettingsService.GetString(SettingKeys.LeagueId);
        await using var dbContext = new SidekickDbContext(DbContextOptions);
        TrackedTabs = await dbContext.WealthStashes.Where(x => x.League == leagueId).ToListAsync();
    }

    private bool IsChecked(StashTab tab) => TrackedTabs.Any(x => x.Id == tab.Id);

    private async Task Toggle(StashTab tab, bool isChecked)
    {
        var trackedTab = TrackedTabs.FirstOrDefault(x => x.Id == tab.Id);

        await using var dbContext = new SidekickDbContext(DbContextOptions);
        var dbStash = await dbContext.WealthStashes.Where(x => x.Id == tab.Id).FirstOrDefaultAsync();

        if (isChecked)
        {
            var leagueId = await SettingsService.GetString(SettingKeys.LeagueId);
            if (leagueId == null) return;

            if (dbStash != null)
            {
                dbStash.Name = tab.Name;
                dbStash.League = leagueId;
                dbStash.Type = tab.Type.ToString();
                dbStash.Total = 0;
                dbStash.LastUpdate = DateTimeOffset.Now;
                dbStash.Selected = true;
            }
            else
            {
                dbStash = new WealthStash()
                {
                    Id = tab.Id,
                    Name = tab.Name,
                    League = leagueId,
                    Type = tab.Type.ToString(),
                    Total = 0,
                    LastUpdate = DateTimeOffset.Now,
                    Selected = true,
                };
                dbContext.WealthStashes.Add(dbStash);
            }

            if (trackedTab == null) TrackedTabs.Add(dbStash);
        }
        else
        {
            if (trackedTab != null) TrackedTabs.Remove(trackedTab);
            if (dbStash != null) dbContext.WealthStashes.Remove(dbStash);
        }

        await dbContext.SaveChangesAsync();

        WealthProvider.SelectedStashesChanged();
    }

    public void Dispose()
    {
        WealthProvider.OnStatusChanged -= OnChanged;
    }
}
