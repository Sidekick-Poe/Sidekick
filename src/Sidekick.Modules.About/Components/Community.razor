@using Microsoft.Extensions.Localization
@using Sidekick.Common.Browser
@using Sidekick.Common.Ui.Forms
@using Sidekick.Common.Ui.Buttons
@using Sidekick.Common.Ui.Typography
@using Sidekick.Modules.About.Localization

<FormFieldset Legend="@Resources["Community"]" Class="flex flex-col justify-start">
    <div class="flex items-center gap-3">
        <TextBase>@Resources["Discord_Server"]</TextBase>
        <ButtonLink OnClick="@(() => BrowserProvider.OpenUri(BrowserProvider.DiscordServer))"
                    Class="text-sm text-neutral-400">@BrowserProvider.DiscordServer</ButtonLink>
    </div>
</FormFieldset>

@inject IStringLocalizer<AboutResources> Resources
@inject IBrowserProvider BrowserProvider
